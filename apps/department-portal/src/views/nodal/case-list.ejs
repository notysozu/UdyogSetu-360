<section class="card"><h2>Cross-department cases</h2><div class="table-wrap"><table><caption>Cases requiring coordination</caption><thead><tr><th>Case</th><th>Departments</th><th>Tasks</th><th>Overdue</th></tr></thead><tbody><% cases.forEach(function(item) { %><tr><td><a href="/nodal/cases/<%= item.universalCaseId %>"><%= item.universalCaseId %></a></td><td><%= item.departments.map(function(dep) { return view.departmentLabel(dep); }).join(', ') %></td><td><%= item.taskCount %></td><td><%= item.overdueCount %></td></tr><% }) %></tbody></table></div></section>
