<section class="card"><h2>Escalations</h2><div class="table-wrap"><table><caption>Escalated or delayed cases</caption><thead><tr><th>Case</th><th>Departments</th><th>Overdue count</th></tr></thead><tbody><% cases.forEach(function(item) { %><tr><td><a href="/nodal/cases/<%= item.universalCaseId %>"><%= item.universalCaseId %></a></td><td><%= item.departments.map(function(dep) { return view.departmentLabel(dep); }).join(', ') %></td><td><%= item.overdueCount %></td></tr><% }) %></tbody></table></div></section>
