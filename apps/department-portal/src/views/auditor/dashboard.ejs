<section class="kpi-grid"><article class="kpi-card"><h2>Auditable tasks</h2><p><%= dashboard.taskCount %></p></article><article class="kpi-card"><h2>Overdue</h2><p><%= dashboard.overdueCount %></p></article></section>
<section class="card"><h2>Recent tasks</h2><% dashboard.recentTasks.forEach(function(task) { %><%- include('../partials/department/task-card', { task: task, href: '/audit/tasks/' + task._id }) %><% }) %></section>
