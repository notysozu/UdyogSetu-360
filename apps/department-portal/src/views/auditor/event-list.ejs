<section class="card"><h2>Audit events</h2><div class="table-wrap"><table><caption>Audit event list</caption><thead><tr><th>Time</th><th>Action</th><th>Resource</th><th>Correlation</th></tr></thead><tbody><% events.forEach(function(event) { %><tr><td><%= view.formatDateTime(event.createdAt, currentLocale) %></td><td><%= event.action %></td><td><%= event.resourceType %> / <%= event.resourceId %></td><td><%= event.correlationId || '—' %></td></tr><% }) %></tbody></table></div></section>
