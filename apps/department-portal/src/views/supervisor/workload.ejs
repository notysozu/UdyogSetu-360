<section class="card"><h2>Department workload</h2><p>Total tasks: <%= workload.total %></p><p>Unassigned: <%= workload.unassigned %></p><p>Overdue: <%= workload.overdue %></p></section>
<section class="card"><h2>Officer distribution</h2><div class="table-wrap"><table><caption>Officer workloads</caption><thead><tr><th>Officer</th><th>Active tasks</th><th>Overdue tasks</th></tr></thead><tbody><% officers.forEach(function(officer) { %><tr><td><%= officer.officerLabel %></td><td><%= officer.activeTaskCount %></td><td><%= officer.overdueTaskCount %></td></tr><% }) %></tbody></table></div></section>
