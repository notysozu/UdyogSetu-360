<section class="card"><h2>SLA dashboard</h2><div class="table-wrap"><table><caption>Task SLA overview</caption><thead><tr><th>Task</th><th>Status</th><th>Due</th></tr></thead><tbody><% tasks.forEach(function(task) { %><tr><td><a href="/supervisor/tasks/<%= task._id %>"><%= task.title %></a></td><td><%= view.statusLabel(task.status) %></td><td><%= view.formatDate(task.dueAt, currentLocale) %></td></tr><% }) %></tbody></table></div></section>
