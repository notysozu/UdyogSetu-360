<article class="timeline-item">
  <p class="timeline-item__meta"><%= view.formatDateTime(item.occurredAt || item.createdAt, currentLocale) %></p>
  <h3><%= item.payload?.title || view.statusLabel(item.type) %></h3>
  <p><%= item.payload?.description || item.payload?.message || 'Activity recorded in the case timeline.' %></p>
  <% if (item.payload?.departmentCode) { %>
    <p class="timeline-item__detail">Department: <%= view.departmentLabel(item.payload.departmentCode) %></p>
  <% } %>
</article>
