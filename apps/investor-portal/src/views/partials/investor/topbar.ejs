<header class="topbar" role="banner">
  <div class="topbar__inner">
    <button class="topbar__toggle" type="button" data-sidebar-toggle aria-expanded="false" aria-controls="investor-sidebar">Menu</button>
    <div>
      <p class="topbar__eyebrow">UdyogSetu 360</p>
      <h1 class="topbar__title"><%= title || t('dashboard', 'Dashboard') %></h1>
    </div>
    <div class="topbar__actions">
      <%- include('./language-switcher') %>
      <% if (currentUser) { %>
        <a class="topbar__link" href="/notifications">Notifications</a>
        <form method="post" action="/auth/logout">
          <button class="button button--secondary" type="submit">Sign out</button>
        </form>
      <% } %>
    </div>
  </div>
</header>
