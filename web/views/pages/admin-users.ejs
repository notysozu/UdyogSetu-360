<section class="content-shell">
  <div class="section-heading">
    <p class="eyebrow">Administration</p>
    <h1>User Management</h1>
  </div>
  <div class="table-wrap">
    <table>
      <caption>Users in the UdyogSetu 360 portal</caption>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((item) => { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.email %></td>
            <td><%= item.primaryRole || item.role %></td>
            <td><%= item.status %></td>
            <td><a href="/admin/users/<%= item._id %>">Manage</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
