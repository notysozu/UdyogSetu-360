    <section
      class="<%= hasSavedCookieConsent ? 'hidden ' : '' %>fixed inset-x-0 bottom-0 z-50 border-t border-slate-200 bg-white px-4 py-4 shadow-[0_-16px_40px_rgba(15,23,42,0.12)] sm:px-6"
      aria-label="Cookie notice"
      data-cookie-banner
    >
      <div class="mx-auto flex max-w-7xl flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="max-w-3xl text-sm leading-6 text-slate-700">
            We use cookies to improve your experience on UdyogSetu 360, measure portal performance, and support secure government service delivery. You can accept all cookies or manage optional cookies.
          </p>
          <p class="mt-1 hidden text-sm font-bold text-[var(--gov-red)]" data-cookie-status role="status"></p>
        </div>
        <div class="grid gap-2 sm:grid-cols-3 lg:min-w-[620px]" data-cookie-actions>
          <button class="focus-ring rounded-sm border border-slate-400 px-4 py-3 text-xs font-extrabold uppercase tracking-wide text-slate-900 hover:bg-slate-100" type="button" data-cookie-open-customize>
            Customize Cookies
          </button>
          <button class="focus-ring rounded-sm border border-slate-400 px-4 py-3 text-xs font-extrabold uppercase tracking-wide text-slate-900 hover:bg-slate-100" type="button" data-cookie-action="decline_optional">
            Decline Optional Cookies
          </button>
          <button class="focus-ring rounded-sm bg-[var(--gov-red)] px-4 py-3 text-xs font-extrabold uppercase tracking-wide text-white hover:bg-[#a01825]" type="button" data-cookie-action="accept_all">
            Accept All Cookies
          </button>
        </div>
      </div>
    </section>

    <div class="fixed inset-0 z-[60] hidden items-center justify-center bg-slate-950/70 px-4 py-8" data-cookie-modal>
      <section class="max-h-[calc(100vh-4rem)] w-full max-w-2xl overflow-y-auto rounded-md bg-white p-6 shadow-2xl sm:p-7" role="dialog" aria-modal="true" aria-labelledby="cookie-settings-title">
        <div class="flex items-start justify-between gap-4 border-b border-slate-200 pb-4">
          <div>
            <p class="text-sm font-extrabold uppercase tracking-[0.2em] text-[var(--gov-red)]">Cookie settings</p>
            <h2 id="cookie-settings-title" class="mt-2 text-2xl font-extrabold text-slate-950">Manage optional cookies</h2>
          </div>
          <button class="focus-ring flex h-10 w-10 items-center justify-center rounded-sm border border-slate-300 text-slate-700 hover:bg-slate-100" type="button" aria-label="Close cookie settings" data-cookie-close-customize>
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
        </div>

        <form class="mt-5 grid gap-4" data-cookie-customize-form>
          <div class="rounded-md border border-slate-200 bg-slate-50 p-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-extrabold text-slate-950">Necessary cookies</h3>
                <p class="mt-1 text-sm leading-6 text-slate-600">Required for secure sessions, service routing and core portal operation.</p>
              </div>
              <span class="rounded-sm bg-slate-900 px-3 py-1 text-xs font-extrabold uppercase tracking-wide text-white">Always on</span>
            </div>
          </div>

          <label class="flex cursor-pointer items-start justify-between gap-4 rounded-md border border-slate-200 bg-white p-4 hover:bg-slate-50">
            <span>
              <span class="block font-extrabold text-slate-950">Performance analytics</span>
              <span class="mt-1 block text-sm leading-6 text-slate-600">Helps measure landing page usage, search interactions and service discovery patterns.</span>
            </span>
            <input class="mt-1 h-5 w-5 accent-[var(--gov-red)]" type="checkbox" name="analytics" checked>
          </label>

          <label class="flex cursor-pointer items-start justify-between gap-4 rounded-md border border-slate-200 bg-white p-4 hover:bg-slate-50">
            <span>
              <span class="block font-extrabold text-slate-950">Preference cookies</span>
              <span class="mt-1 block text-sm leading-6 text-slate-600">Remembers language, accessibility and display preferences for return visits.</span>
            </span>
            <input class="mt-1 h-5 w-5 accent-[var(--gov-red)]" type="checkbox" name="preferences" checked>
          </label>

          <div class="mt-2 grid gap-2 sm:grid-cols-3">
            <button class="focus-ring rounded-sm border border-slate-400 px-4 py-3 text-xs font-extrabold uppercase tracking-wide text-slate-900 hover:bg-slate-100" type="button" data-cookie-action="decline_optional">
              Decline Optional
            </button>
            <button class="focus-ring rounded-sm border border-slate-400 px-4 py-3 text-xs font-extrabold uppercase tracking-wide text-slate-900 hover:bg-slate-100" type="submit">
              Save Choices
            </button>
            <button class="focus-ring rounded-sm bg-[var(--gov-red)] px-4 py-3 text-xs font-extrabold uppercase tracking-wide text-white hover:bg-[#a01825]" type="button" data-cookie-action="accept_all">
              Accept All
            </button>
          </div>
        </form>
      </section>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const menuToggle = document.querySelector('[data-menu-toggle]');
        const mobileMenu = document.querySelector('[data-mobile-menu]');
        const calendarToggle = document.querySelector('[data-calendar-toggle]');
        const calendarPanel = document.querySelector('[data-calendar-panel]');
        const calendarDate = document.querySelector('[data-calendar-date]');
        const languageSelect = document.querySelector('[data-language-select]');

        if (calendarDate) {
          calendarDate.textContent = new Intl.DateTimeFormat('en-IN', {
            weekday: 'long',
            day: 'numeric',
            month: 'long',
            year: 'numeric'
          }).format(new Date());
        }

        const closeMenu = () => {
          if (!menuToggle || !mobileMenu) return;
          mobileMenu.classList.add('hidden');
          menuToggle.setAttribute('aria-expanded', 'false');
        };

        menuToggle?.addEventListener('click', () => {
          if (!mobileMenu) return;
          const isOpen = !mobileMenu.classList.contains('hidden');
          mobileMenu.classList.toggle('hidden', isOpen);
          menuToggle.setAttribute('aria-expanded', String(!isOpen));
        });

        mobileMenu?.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });

        calendarToggle?.addEventListener('click', () => {
          if (!calendarPanel) return;
          const isOpen = !calendarPanel.classList.contains('hidden');
          calendarPanel.classList.toggle('hidden', isOpen);
          calendarToggle.setAttribute('aria-expanded', String(!isOpen));
        });

        document.querySelector('[data-share-page]')?.addEventListener('click', async () => {
          const shareData = {
            title: document.title,
            text: 'UdyogSetu 360 - Karnataka interoperability platform',
            url: window.location.href
          };

          try {
            if (navigator.share) {
              await navigator.share(shareData);
              return;
            }

            await navigator.clipboard?.writeText(window.location.href);
            window.alert('Page link copied.');
          } catch (_error) {}
        });

        languageSelect?.addEventListener('change', () => {
          languageSelect.form?.submit();
        });

        document.querySelectorAll('[data-card-href]').forEach((card) => {
          const openCard = () => {
            window.location.href = card.dataset.cardHref;
          };

          card.addEventListener('click', (event) => {
            if (event.target.closest('a, button, input, select, textarea')) return;
            openCard();
          });

          card.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              openCard();
            }
          });
        });

        document.addEventListener('click', (event) => {
          if (mobileMenu && menuToggle && !mobileMenu.contains(event.target) && !menuToggle.contains(event.target)) {
            closeMenu();
          }
          if (calendarPanel && calendarToggle && !calendarPanel.contains(event.target) && !calendarToggle.contains(event.target)) {
            calendarPanel.classList.add('hidden');
            calendarToggle.setAttribute('aria-expanded', 'false');
          }
        });

        const banner = document.querySelector('[data-cookie-banner]');
        const modal = document.querySelector('[data-cookie-modal]');
        const customizeForm = document.querySelector('[data-cookie-customize-form]');
        const status = document.querySelector('[data-cookie-status]');

        if (!banner) return;

        const setStatus = (message) => {
          if (!status) return;
          status.textContent = message;
          status.classList.toggle('hidden', !message);
        };

        const setBusy = (isBusy) => {
          document.querySelectorAll('[data-cookie-action], [data-cookie-open-customize], [data-cookie-close-customize], [data-cookie-customize-form] button').forEach((button) => {
            button.disabled = isBusy;
            button.classList.toggle('opacity-60', isBusy);
            button.classList.toggle('cursor-not-allowed', isBusy);
          });
        };

        const closeModal = () => {
          if (!modal) return;
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          document.body.classList.remove('overflow-hidden');
        };

        const hideBanner = () => {
          banner.classList.add('hidden');
          document.body.classList.remove('pb-48', 'md:pb-28');
          closeModal();
        };

        const saveConsent = async (payload) => {
          setBusy(true);
          setStatus('');

          try {
            const response = await fetch('/cookies/consent', {
              method: 'POST',
              headers: {
                Accept: 'application/json',
                'Content-Type': 'application/json'
              },
              credentials: 'same-origin',
              body: JSON.stringify(payload)
            });

            if (!response.ok) throw new Error('Cookie preference could not be saved.');

            hideBanner();
          } catch (_error) {
            setStatus('We could not save your cookie preference. Please try again.');
          } finally {
            setBusy(false);
          }
        };

        document.querySelectorAll('[data-cookie-action]').forEach((button) => {
          button.addEventListener('click', () => {
            saveConsent({ action: button.dataset.cookieAction });
          });
        });

        document.querySelector('[data-cookie-open-customize]')?.addEventListener('click', () => {
          if (!modal) return;
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          document.body.classList.add('overflow-hidden');
          modal.querySelector('input[name="analytics"]')?.focus();
        });

        document.querySelector('[data-cookie-close-customize]')?.addEventListener('click', closeModal);

        modal?.addEventListener('click', (event) => {
          if (event.target === modal) closeModal();
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') closeModal();
        });

        customizeForm?.addEventListener('submit', (event) => {
          event.preventDefault();
          const formData = new FormData(customizeForm);

          saveConsent({
            action: 'customize',
            categories: {
              analytics: formData.has('analytics'),
              preferences: formData.has('preferences')
            }
          });
        });
      });
    </script>
    <script src="/js/accessibility.js" defer></script>
  </body>
</html>
