<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>UdyogSetu 360 | Karnataka Government Interoperability Platform</title>
    <meta
      name="description"
      content="UdyogSetu 360 connects Karnataka's Single Window System with department systems through real-time two-way synchronisation, universal case IDs, SLA tracking, grievance tracking, document verification and audit trails."
    >
    <link rel="stylesheet" href="/css/accessibility.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    >
    <style>
      :root {
        color-scheme: light;
        --gov-navy: #071d35;
        --gov-slate: #102b45;
        --gov-red: #bf1f2f;
        --gov-gold: #f5c044;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: Arial, Helvetica, sans-serif;
        background: #eef2f6;
        color: #102033;
      }

      .hero-bg {
        background-image:
          linear-gradient(118deg, rgba(3, 18, 38, 0.96) 0%, rgba(10, 35, 61, 0.9) 44%, rgba(17, 47, 74, 0.68) 100%),
          url("https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=2200&q=85");
        background-position: center;
        background-size: cover;
      }

      .gov-shadow {
        box-shadow: 0 24px 70px rgba(7, 29, 53, 0.18);
      }

      .quick-link {
        writing-mode: vertical-rl;
        text-orientation: mixed;
      }

      .focus-ring:focus-visible {
        outline: 3px solid #f5c044;
        outline-offset: 3px;
      }

      body.accessibility-mode {
        filter: contrast(1.12);
      }

      body.theme-contrast {
        background: #dfe7ef;
      }

      body.theme-contrast .hero-bg {
        background-image:
          linear-gradient(118deg, rgba(0, 10, 24, 0.98) 0%, rgba(5, 26, 50, 0.94) 48%, rgba(18, 18, 18, 0.82) 100%),
          url("https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=2200&q=85");
      }
    </style>
    <script>
      (function () {
        try {
          var root = document.documentElement;
          var scale = Number(localStorage.getItem('us360_font_scale') || '100');
          if (!Number.isNaN(scale)) root.style.setProperty('--app-font-scale', String(Math.min(140, Math.max(80, scale)) / 100));
          if (localStorage.getItem('us360_high_contrast') === 'true') root.classList.add('a11y-high-contrast');
          if (localStorage.getItem('us360_dark_mode') === 'true') root.classList.add('a11y-dark-mode');
          if (localStorage.getItem('us360_grayscale') === 'true') root.classList.add('a11y-grayscale');
          if (localStorage.getItem('us360_reduce_motion') === 'true') root.classList.add('a11y-reduce-motion');
          if (localStorage.getItem('us360_dyslexia_font') === 'true') root.classList.add('a11y-dyslexia-font');
          if (localStorage.getItem('us360_letter_spacing') === 'true') root.classList.add('a11y-letter-spacing');
          if (localStorage.getItem('us360_highlight_links') === 'true') root.classList.add('a11y-highlight-links');
          if (localStorage.getItem('us360_large_cursor') === 'true') root.classList.add('a11y-large-cursor');
          if (localStorage.getItem('us360_focus_mode') === 'true') root.classList.add('a11y-focus-mode');
          if (localStorage.getItem('us360_screen_reader_mode') === 'true') root.classList.add('a11y-screen-reader-mode');
        } catch (_error) {}
      })();
    </script>
  </head>
