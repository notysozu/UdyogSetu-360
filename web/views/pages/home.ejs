  <% const t = homeCopy[currentLanguage] || homeCopy.en; %>
  <body class="min-h-screen bg-slate-100 <%= hasSavedCookieConsent ? '' : 'pb-48 md:pb-28' %>">
    <%- include('../partials/accessibility-panel') %>
    <header class="hero-bg relative min-h-screen overflow-hidden text-white">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_35%,rgba(255,255,255,0.13),transparent_32rem)]"></div>

      <nav aria-label="Utility links" class="relative z-30 flex justify-end px-4 pt-4 sm:px-8 lg:px-12">
        <div class="relative">
          <div class="flex items-center gap-1.5 rounded-sm border border-white/20 bg-[#06182d]/55 px-2 py-1.5 text-sm shadow-xl backdrop-blur-md sm:gap-2 sm:px-3">
          <button class="focus-ring flex h-9 w-9 items-center justify-center rounded-sm hover:bg-white/10" type="button" aria-label="Show calendar" aria-expanded="false" aria-controls="calendar-panel" data-calendar-toggle>
            <i class="fa-regular fa-calendar-days"></i>
          </button>
          <form method="get" action="/language" class="flex items-center">
            <input type="hidden" name="next" value="/">
            <label class="sr-only-enhanced" for="language-select"><%= t.languageLabel %></label>
            <select id="language-select" name="lang" class="focus-ring h-9 rounded-sm border border-white/20 bg-[#06182d] px-2 text-sm font-bold text-white" aria-label="Select language" data-language-select>
              <option value="en" <%= currentLanguage === 'en' ? 'selected' : '' %>>A English</option>
              <option value="kn" <%= currentLanguage === 'kn' ? 'selected' : '' %>>ಅ Kannada</option>
              <option value="hi" <%= currentLanguage === 'hi' ? 'selected' : '' %>>अ Hindi</option>
            </select>
          </form>
          <button class="focus-ring flex h-9 w-10 flex-col justify-center gap-1 rounded-sm px-2 hover:bg-white/10" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="portal-menu" data-menu-toggle>
            <span class="block h-1 rounded-full bg-[#ff9933]"></span>
            <span class="block h-1 rounded-full bg-white"></span>
            <span class="block h-1 rounded-full bg-[#138808]"></span>
          </button>
          </div>

          <div id="calendar-panel" class="absolute right-0 mt-2 hidden w-64 rounded-sm border border-white/20 bg-white p-4 text-left text-slate-900 shadow-2xl" data-calendar-panel>
            <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-[var(--gov-red)]">Today</p>
            <p class="mt-1 text-lg font-extrabold" data-calendar-date></p>
          </div>

          <div id="portal-menu" class="absolute right-0 mt-2 hidden w-72 overflow-hidden rounded-sm border border-white/20 bg-white text-left text-slate-900 shadow-2xl" data-mobile-menu>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/auth/login"><%= t.login %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/auth/register"><%= t.register %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/cases/new"><%= t.startApplication %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/cases"><%= t.trackApplication %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/department"><%= t.departmentPortal %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/admin"><%= t.admin %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/verify"><%= t.verifyCertificate %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="/grievances/new"><%= t.submitGrievance %></a>
            <a class="block border-b border-slate-200 px-4 py-3 font-bold hover:bg-slate-100" href="#how-it-works"><%= t.learnMore %></a>
            <a class="block px-4 py-3 font-bold hover:bg-slate-100" href="/contact"><%= t.contact %></a>
          </div>
        </div>
      </nav>

      <aside class="fixed right-2 top-[56%] z-40 hidden w-16 -translate-y-1/2 overflow-hidden rounded-md border border-white/30 bg-white text-slate-800 shadow-2xl lg:block xl:right-4 xl:w-10 2xl:right-6" aria-label="Quick links">
        <a class="quick-link flex min-h-24 items-center justify-center border-b border-slate-200 px-2.5 py-3 text-xs font-bold uppercase tracking-wide hover:bg-slate-100" href="/contact?topic=feedback"><%= t.feedback %></a>
        <a class="quick-link flex min-h-24 items-center justify-center border-b border-slate-200 px-2.5 py-3 text-xs font-bold uppercase tracking-wide hover:bg-slate-100" href="/contact?topic=helpdesk"><%= t.helpdesk %></a>
        <a class="quick-link flex min-h-24 items-center justify-center border-b border-slate-200 px-2.5 py-3 text-xs font-bold uppercase tracking-wide hover:bg-slate-100" href="/cases"><%= t.trackCase %></a>
        <button class="quick-link flex min-h-20 items-center justify-center border-b border-slate-200 px-2.5 py-3 text-xs font-bold uppercase tracking-wide hover:bg-slate-100" type="button" data-share-page><%= t.share %></button>
        <button class="quick-link flex min-h-20 items-center justify-center px-2.5 py-3 text-xs font-bold uppercase tracking-wide hover:bg-slate-100" type="button" data-theme-toggle><%= t.theme %></button>
      </aside>

      <section class="relative z-10 mx-auto flex min-h-[calc(100vh-5rem)] max-w-7xl flex-col items-center justify-center px-4 pb-40 pt-12 text-center sm:px-8 lg:px-12">
        <div class="mb-5 flex h-20 w-20 items-center justify-center rounded-full border-2 border-white/75 bg-white/10 text-4xl shadow-2xl backdrop-blur-md sm:h-24 sm:w-24 sm:text-5xl" aria-hidden="true">
          <i class="fa-solid fa-landmark-dome"></i>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <h1 class="text-4xl font-extrabold leading-tight text-white sm:text-6xl lg:text-7xl"><%= t.title %></h1>
          <span class="rounded-sm bg-[var(--gov-gold)] px-3 py-1 text-sm font-extrabold uppercase tracking-wider text-slate-950">Beta</span>
        </div>

        <p class="mt-4 text-xl font-semibold text-white sm:text-2xl"><%= t.tagline %></p>
        <p class="mt-3 text-base font-semibold uppercase tracking-[0.18em] text-amber-200"><%= t.subtitle %></p>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-100 sm:text-lg">
          <%= t.subtitleLine %>
        </p>
        <p class="mt-5 max-w-4xl text-sm leading-7 text-slate-200 sm:text-base">
          <%= t.description %>
        </p>

        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a class="focus-ring rounded-sm bg-[var(--gov-red)] px-5 py-3 text-sm font-extrabold uppercase tracking-wide text-white shadow-xl transition hover:bg-[#a01825]" href="/cases/new"><%= t.startApplication %></a>
          <a class="focus-ring rounded-sm border border-white/35 bg-white/10 px-5 py-3 text-sm font-extrabold uppercase tracking-wide text-white backdrop-blur transition hover:bg-white hover:text-slate-950" href="/cases"><%= t.trackApplication %></a>
          <a class="focus-ring rounded-sm border border-white/35 bg-white/10 px-5 py-3 text-sm font-extrabold uppercase tracking-wide text-white backdrop-blur transition hover:bg-white hover:text-slate-950" href="#how-it-works"><%= t.learnMore %></a>
        </div>

        <form class="mt-9 w-full max-w-5xl rounded-md bg-white p-2 shadow-2xl" action="/search" method="get" role="search">
          <div class="grid gap-2 md:grid-cols-[1fr_190px_150px]">
            <label class="sr-only-enhanced" for="portal-search">Search applications, departments, approvals, certificates...</label>
            <div class="flex items-center gap-3 rounded-sm border border-slate-200 bg-white px-4">
              <i class="fa-solid fa-magnifying-glass text-slate-400" aria-hidden="true"></i>
              <input
                id="portal-search"
                name="q"
                class="focus-ring min-h-14 w-full border-0 bg-transparent text-base text-slate-900 placeholder:text-slate-500 focus:outline-none"
                type="search"
                placeholder="<%= t.searchPlaceholder %>"
              >
            </div>
            <label class="sr-only-enhanced" for="service-filter">Service category</label>
            <select id="service-filter" name="service" class="focus-ring min-h-14 rounded-sm border border-slate-200 bg-slate-50 px-4 font-bold text-slate-800">
              <option value="All Services">All Services</option>
              <option value="Approvals">Approvals</option>
              <option value="Certificates">Certificates</option>
              <option value="Grievances">Grievances</option>
              <option value="Departments">Departments</option>
            </select>
            <button class="focus-ring min-h-14 rounded-sm bg-[var(--gov-red)] px-6 font-extrabold uppercase tracking-wide text-white transition hover:bg-[#a01825]" type="submit">
              <%= t.searchButton %>
            </button>
          </div>
        </form>

        <div class="mt-5 flex max-w-5xl flex-wrap items-center justify-center gap-2 text-sm" aria-label="Trending searches">
          <span class="mr-1 font-bold text-slate-100"><%= t.trending %></span>
          <a class="focus-ring rounded-full border border-white/30 bg-white/10 px-4 py-2 font-semibold text-white backdrop-blur transition hover:bg-white hover:text-slate-900" href="/search?q=Universal%20Case%20ID">Universal Case ID</a>
          <a class="focus-ring rounded-full border border-white/30 bg-white/10 px-4 py-2 font-semibold text-white backdrop-blur transition hover:bg-white hover:text-slate-900" href="/search?q=Pollution%20Clearance">Pollution Clearance</a>
          <a class="focus-ring rounded-full border border-white/30 bg-white/10 px-4 py-2 font-semibold text-white backdrop-blur transition hover:bg-white hover:text-slate-900" href="/search?q=Power%20Connection">Power Connection</a>
          <a class="focus-ring rounded-full border border-white/30 bg-white/10 px-4 py-2 font-semibold text-white backdrop-blur transition hover:bg-white hover:text-slate-900" href="/search?q=Fire%20NOC">Fire NOC</a>
