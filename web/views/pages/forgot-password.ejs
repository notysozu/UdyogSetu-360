<section class="auth-panel">
  <div>
    <p class="eyebrow">Account recovery</p>
    <h1>Forgot your password?</h1>
    <p>Enter your email address and we will generate reset instructions.</p>
  </div>
  <form class="card form-card" method="post" action="/auth/forgot-password">
    <% if (errors && errors.length) { %>
      <div class="alert alert-error" role="alert" aria-live="assertive">
        <% errors.forEach((item) => { %><div><%= item %></div><% }) %>
      </div>
    <% } %>
    <label>Email
      <input name="email" type="email" autocomplete="email" required value="<%= values?.email || '' %>">
    </label>
    <button class="button" type="submit">Send reset instructions</button>
    <p><a href="/auth/login">Back to sign in</a></p>
  </form>
</section>
