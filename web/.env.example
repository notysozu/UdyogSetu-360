NODE_ENV=development
PORT=3000
SESSION_SECRET=replace-this-with-a-long-random-secret
JWT_SECRET=replace-this-with-a-different-long-random-secret
JWT_REFRESH_SECRET=replace-this-with-a-refresh-secret
JWT_ISSUER=udyogsetu-360
JWT_AUDIENCE=udyogsetu-360-web
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=replace-this-with-a-cookie-secret
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_VERIFICATION_EXPIRES_MINUTES=60
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
SERVICE_JWT_SECRET=replace-this-with-a-service-jwt-secret
INTERNAL_SERVICE_TOKEN=replace-this-with-an-internal-service-token
TRUSTED_SERVICE_NAMES=gateway,case-service,notification-service,n8n
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=
MONGO_URI=
AI_SERVICE_URL=http://127.0.0.1:8000
N8N_WEBHOOK_SECRET=dev-n8n-secret
CASE_ID_PREFIX=US360-KA
ACK_PREFIX=ACK-US360-KA
CAF_AUTOSAVE_ENABLED=true
CAF_DUPLICATE_LOOKBACK_DAYS=180
ATTACHMENT_STORAGE_PROVIDER=s3
S3_BUCKET=udyogsetu-documents
SLA_EVALUATION_INTERVAL_MINUTES=15
SLA_WARNING_PERCENTAGE=80
ORCHESTRATION_ENABLE_REPLAY=true
ORCHESTRATION_ALLOW_ADMIN_OVERRIDE=true
ORCHESTRATION_LOG_TRANSITIONS=true
